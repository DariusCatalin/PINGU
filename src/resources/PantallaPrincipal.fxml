<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<!-- StackPane como raíz para centrar el contenido y poner fondo negro en los bordes -->
<StackPane style="-fx-background-color: #000000;" stylesheets="@PantallaPrincipal.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JOC_DEL_PINGU.PantallaPrincipal">

    <!-- Panel de tamaño fijo centrado en la pantalla -->
    <AnchorPane prefHeight="850" prefWidth="1330" maxHeight="850" maxWidth="1330">

        <!-- Imagen de fondo con los botones ya dibujados -->
        <ImageView fitHeight="850" fitWidth="1330" preserveRatio="false">
            <image>
                <Image url="@FONDO%20MENÚ.png" />
            </image>
        </ImageView>

        <!-- Botón transparente sobre NUEVA PARTIDA -->
        <Button fx:id="btnNuevaPartida" layoutX="510" layoutY="340.0" onAction="#handleNuevaPartida" prefHeight="114.0" prefWidth="310" styleClass="btn-invisible" />

        <!-- Botón transparente sobre CARGAR PARTIDA -->
        <Button fx:id="btnCargarPartida" layoutX="510" layoutY="476.0" onAction="#handleCargarPartida" prefHeight="114.0" prefWidth="310" styleClass="btn-invisible" />

        <!-- Botón transparente sobre VOLVER AL LOGIN -->
        <Button fx:id="btnVolverLogin" layoutX="510" layoutY="621.0" onAction="#handleVolverLogin" prefHeight="114.0" prefWidth="310" styleClass="btn-invisible" />

    </AnchorPane>

</StackPane>
