<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="850" prefWidth="1330" stylesheets="@PantallaPrincipal.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JOC_DEL_PINGU.PantallaPrincipal">

    <!-- Imagen de fondo con los botones ya dibujados -->
    <ImageView fitHeight="850" fitWidth="1330" preserveRatio="false" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">
        <image>
            <Image url="@FONDO%20MENÚ.png" />
        </image>
    </ImageView>

    <!-- Botón invisible sobre NUEVA PARTIDA -->
    <Button fx:id="btnNuevaPartida" layoutX="510" layoutY="340.0" onAction="#handleNuevaPartida" prefHeight="114.0" prefWidth="310" styleClass="btn-invisible" visible="false" />

    <!-- Botón invisible sobre CARGAR PARTIDA -->
    <Button fx:id="btnCargarPartida" layoutX="510" layoutY="476.0" onAction="#handleCargarPartida" prefHeight="114.0" prefWidth="310" styleClass="btn-invisible" visible="false" />

    <!-- Botón invisible sobre VOLVER AL LOGIN -->
    <Button fx:id="btnVolverLogin" layoutX="510" layoutY="621.0" onAction="#handleVolverLogin" prefHeight="114.0" prefWidth="310" styleClass="btn-invisible" visible="false" />

</AnchorPane>
