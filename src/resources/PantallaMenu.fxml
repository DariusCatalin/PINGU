<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<StackPane styleClass="login-bg"
           stylesheets="@PantallaMenu.css"
           fx:controller="JOC_DEL_PINGU.PantallaMenu"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1">

    <!-- Imagen de fondo centrada, tamaño fijo 1170x658 (sin deformar) -->
    <ImageView fitWidth="1170" fitHeight="658" preserveRatio="true">
        <image>
            <Image url="@inicio_sesion.png" />
        </image>
    </ImageView>

    <!-- Panel transparente 1170x658 centrado sobre la imagen, con los controles -->
    <AnchorPane prefHeight="658" prefWidth="1170"
                maxHeight="658" maxWidth="1170"
                minHeight="658" minWidth="1170"
                style="-fx-background-color: transparent;"
                pickOnBounds="false">

        <!-- Campo Usuario -->
        <TextField fx:id="userField"
                   layoutX="445" layoutY="269"
                   prefHeight="44" prefWidth="392"
                   promptText="Usuario"
                   styleClass="login-field" />

        <!-- Campo Contraseña -->
        <PasswordField fx:id="passField"
                       layoutX="445" layoutY="329"
                       prefHeight="44" prefWidth="392"
                       promptText="Contraseña"
                       styleClass="login-field" />

        <!-- Botón INICIAR SESIÓN -->
        <Button fx:id="loginButton"
                contentDisplay="GRAPHIC_ONLY"
                layoutX="451" layoutY="383"
                prefHeight="77" prefWidth="170"
                onAction="#handleLogin"
                styleClass="btn-login">
            <graphic>
                <ImageView fitHeight="77" fitWidth="170" preserveRatio="false">
                    <image>
                        <Image url="@iniciar_sesion_boton.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>

        <!-- Botón REGISTRARSE -->
        <Button fx:id="registerButton"
                contentDisplay="GRAPHIC_ONLY"
                layoutX="640" layoutY="383"
                prefHeight="77" prefWidth="193"
                onAction="#handleRegister"
                styleClass="btn-register">
            <graphic>
                <ImageView fitHeight="77" fitWidth="193" preserveRatio="false">
                    <image>
                        <Image url="@registro_boton.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>

        <!-- Label de error -->
        <Label fx:id="lblError"
               layoutX="445" layoutY="480"
               prefWidth="392"
               styleClass="lbl-error"
               visible="false"
               managed="false"
               alignment="CENTER"
               wrapText="true" />

    </AnchorPane>

</StackPane>
