<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>



<AnchorPane prefHeight="1080" prefWidth="1920" styleClass="login-bg" stylesheets="@PantallaMenu.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JOC_DEL_PINGU.PantallaMenu">

    <!-- ============ CAMPO USUARIO ============ -->
    <TextField fx:id="userField" layoutX="733.0" layoutY="411.0" prefHeight="95.0" prefWidth="646.0" promptText="Nombre de usuario" styleClass="transparent-field" />

    <!-- ============ CAMPO CONTRASEÑA ============ -->
    <PasswordField fx:id="passField" layoutX="733.0" layoutY="540.0" prefHeight="95.0" prefWidth="646.0" promptText="Contraseña" styleClass="transparent-field" />

    <!-- ============ BOTÓN INICIAR SESIÓN (invisible) ============ -->
    <Button fx:id="loginButton" layoutX="727.0" layoutY="675.0" onAction="#handleLogin" prefHeight="147.0" prefWidth="316.0" styleClass="invisible-button" text="" />

    <!-- ============ BOTÓN REGISTRARSE (invisible) ============ -->
    <Button fx:id="registerButton" layoutX="1075.0" layoutY="678.0" onAction="#handleRegister" prefHeight="141.0" prefWidth="316.0" styleClass="invisible-button" text="" />

    <!-- ============ MENSAJE DE ERROR ============ -->
    <Label fx:id="lblError" alignment="CENTER" layoutX="710" layoutY="850" managed="false" prefWidth="500" styleClass="lbl-error" text="" visible="false" wrapText="true" />

</AnchorPane>
