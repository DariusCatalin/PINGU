<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    INICIO DE SESIÓN
    Capas (de atrás hacia delante):
      1. Fondo del paisaje (CSS .login-bg)
      2. ImageView con el panel de hielo (centrado)
      3. VBox con los campos y botones reales (centrado dentro del panel)
-->
<StackPane fx:id="rootPane"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="JOC_DEL_PINGU.PantallaMenu"
    stylesheets="@PantallaMenu.css"
    styleClass="login-bg">

    <!-- CAPA 1: Panel de hielo (centrado) -->
    <ImageView fitWidth="1700" preserveRatio="true"
               pickOnBounds="false" mouseTransparent="true"
               StackPane.alignment="CENTER">
        <image>
            <Image url="@resources/inicio_sesion_plantilla.png"/>
        </image>
    </ImageView>

    <!-- CAPA 2: Campos y botones reales -->
    <VBox alignment="TOP_CENTER"
          maxWidth="600" maxHeight="520"
          StackPane.alignment="CENTER">

        <!-- Espacio para el título dibujado en la plantilla -->
        <Region prefHeight="155"/>

        <!-- CAMPO USUARIO -->
        <TextField fx:id="userField"
                   promptText="Usuario"
                   styleClass="login-field"
                   prefHeight="50" maxWidth="480"/>

        <Region prefHeight="22"/>

        <!-- CAMPO CONTRASEÑA -->
        <PasswordField fx:id="passField"
                       promptText="Contraseña"
                       styleClass="login-field"
                       prefHeight="50" maxWidth="480"/>

        <Region prefHeight="35"/>

        <!-- BOTONES centrados y más grandes -->
        <HBox spacing="60" alignment="CENTER">
            <Button fx:id="loginButton"
                    onAction="#handleLogin"
                    styleClass="btn-login"
                    prefWidth="260" prefHeight="110"/>
            <Button fx:id="registerButton"
                    onAction="#handleRegister"
                    styleClass="btn-register"
                    prefWidth="260" prefHeight="110"/>
        </HBox>

        <Region prefHeight="15"/>

        <!-- Mensaje de error -->
        <Label fx:id="lblError" text=""
               styleClass="error-label"
               wrapText="true"
               visible="false" managed="false"/>
    </VBox>

</StackPane>
