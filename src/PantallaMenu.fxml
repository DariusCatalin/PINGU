<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    INICIO DE SESIÓN
    - inicio_sesion.png cubre toda la pantalla como fondo (CSS)
    - VBox centrado superpone los campos sobre los recuadros del panel
    - Botones con imagen usando CSS background-image
-->
<StackPane fx:id="rootPane"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="JOC_DEL_PINGU.PantallaMenu"
    stylesheets="@PantallaMenu.css"
    styleClass="login-bg">

    <!-- VBox centrado sobre el panel del fondo -->
    <VBox alignment="TOP_CENTER"
          maxWidth="490"
          StackPane.alignment="CENTER"
          translateY="-35">

        <!-- Espaciado hasta el primer campo (ocupa título + margen) -->
        <Region prefHeight="155"/>

        <!-- CAMPO USUARIO -->
        <TextField fx:id="userField"
                   promptText="Usuario"
                   styleClass="login-field"
                   prefHeight="52" maxWidth="390"/>

        <!-- Separación entre los dos campos -->
        <Region prefHeight="58"/>

        <!-- CAMPO CONTRASEÑA -->
        <PasswordField fx:id="passField"
                       promptText="Contraseña"
                       styleClass="login-field"
                       prefHeight="52" maxWidth="390"/>

        <!-- Espacio antes de los botones -->
        <Region prefHeight="48"/>

        <!-- BOTONES con imagen -->
        <HBox spacing="35" alignment="CENTER">
            <Button fx:id="loginButton"
                    onAction="#handleLogin"
                    styleClass="btn-login"
                    prefWidth="190" prefHeight="78"/>
            <Button fx:id="registerButton"
                    onAction="#handleRegister"
                    styleClass="btn-register"
                    prefWidth="190" prefHeight="78"/>
        </HBox>

        <Region prefHeight="12"/>

        <!-- Mensaje de error -->
        <Label fx:id="lblError" text=""
               styleClass="error-label"
               wrapText="true"
               visible="false" managed="false"/>
    </VBox>

</StackPane>
