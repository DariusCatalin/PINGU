<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    INICIO DE SESIÓN
    La imagen de fondo (inicio_sesion.png) tiene dibujados:
      - Título "INICIO DE SESIÓN" (zona superior del panel de hielo)
      - 2 campos de entrada (usuario / contraseña)
      - 2 botones: "INICIAR SESIÓN" (izquierda) y "REGISTRARSE" (derecha)

    Los elementos JavaFX son TRANSPARENTES y se superponen exactamente
    sobre los elementos pintados en la imagen.
    Ajusta los valores de Region si tu resolución desplaza el panel.
-->
<StackPane
    xmlns="http://javafx.com/javafx/21.0.10"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="JOC_DEL_PINGU.PantallaMenu"
    stylesheets="@PantallaMenu.css"
    styleClass="login-bg">

    <!-- Contenedor centrado que cubre exactamente el panel de hielo de la imagen -->
    <VBox alignment="CENTER"
          maxWidth="680" maxHeight="520"
          StackPane.alignment="CENTER">

        <!-- Espacio para el título "INICIO DE SESIÓN" pintado en la imagen -->
        <Region prefHeight="105"/>

        <!-- CAMPO USUARIO -->
        <TextField fx:id="userField"
                   promptText="Usuario..."
                   styleClass="transparent-field"
                   prefHeight="48" maxWidth="390"/>

        <Region prefHeight="22"/>

        <!-- CAMPO CONTRASEÑA -->
        <PasswordField fx:id="passField"
                       promptText="Contraseña..."
                       styleClass="transparent-field"
                       prefHeight="48" maxWidth="390"/>

        <!-- Espacio hasta los botones de la imagen -->
        <Region prefHeight="68"/>

        <!-- BOTONES (transparentes, superpuestos sobre los de la imagen) -->
        <HBox spacing="0" alignment="CENTER">
            <Button fx:id="loginButton"
                    text="" onAction="#handleLogin"
                    styleClass="transparent-button"
                    prefWidth="210" prefHeight="72"/>
            <Region prefWidth="58"/>
            <Button fx:id="registerButton"
                    text="" onAction="#handleRegister"
                    styleClass="transparent-button"
                    prefWidth="210" prefHeight="72"/>
        </HBox>

        <Region prefHeight="8"/>

        <!-- Mensaje de error (visible solo si hay error) -->
        <Label fx:id="lblError" text=""
               styleClass="error-label"
               wrapText="true"
               visible="false" managed="false"/>
    </VBox>

</StackPane>
