<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="25.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="JOC_DEL_PINGU.PantallaConfig"
      stylesheets="@PantallaConfig.css"
      styleClass="main-menu-bg">

    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <!-- TÍTULO -->
    <VBox alignment="CENTER" spacing="6.0" styleClass="title-container">
        <Label text="NUEVA PARTIDA" styleClass="main-title">
            <font><Font name="System Bold" size="38.0" /></font>
        </Label>
        <Label text="Configura los jugadores antes de empezar" styleClass="sub-title" />
    </VBox>

    <!-- PANEL PRINCIPAL -->
    <VBox spacing="20.0" styleClass="config-panel">

        <!-- Nº DE JUGADORES -->
        <VBox spacing="10.0">
            <Label text="¿Cuántos jugadores?" styleClass="config-label" />
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Button fx:id="btn2J" text="2" onAction="#seleccionar2" styleClass="toggle-btn, toggle-active" prefWidth="60" />
                <Button fx:id="btn3J" text="3" onAction="#seleccionar3" styleClass="toggle-btn" prefWidth="60" />
                <Button fx:id="btn4J" text="4" onAction="#seleccionar4" styleClass="toggle-btn" prefWidth="60" />
            </HBox>
        </VBox>

        <!-- CPU (FOCA) -->
        <CheckBox fx:id="chkCPU" text="Añadir CPU (La Foca)" styleClass="config-checkbox" onAction="#toggleCPU" />

        <!-- FILA JUGADOR 1 -->
        <HBox fx:id="filaJ1" spacing="12.0" alignment="CENTER_LEFT" styleClass="player-row">
            <Label text="Jugador 1" styleClass="player-label" prefWidth="80" />
            <ComboBox fx:id="nombreJ1" promptText="Escribe tu nombre..." styleClass="config-field" prefWidth="200" />
            <ComboBox fx:id="colorJ1" promptText="Color" styleClass="config-combo" prefWidth="130" />
        </HBox>

        <!-- FILA JUGADOR 2 -->
        <HBox fx:id="filaJ2" spacing="12.0" alignment="CENTER_LEFT" styleClass="player-row">
            <Label text="Jugador 2" styleClass="player-label" prefWidth="80" />
            <ComboBox fx:id="nombreJ2" promptText="Escribe tu nombre..." styleClass="config-field" prefWidth="200" />
            <ComboBox fx:id="colorJ2" promptText="Color" styleClass="config-combo" prefWidth="130" />
        </HBox>

        <!-- FILA JUGADOR 3 -->
        <HBox fx:id="filaJ3" spacing="12.0" alignment="CENTER_LEFT" styleClass="player-row">
            <Label text="Jugador 3" styleClass="player-label" prefWidth="80" />
            <ComboBox fx:id="nombreJ3" promptText="Escribe tu nombre..." styleClass="config-field" prefWidth="200" />
            <ComboBox fx:id="colorJ3" promptText="Color" styleClass="config-combo" prefWidth="130" />
        </HBox>

        <!-- FILA JUGADOR 4 -->
        <HBox fx:id="filaJ4" spacing="12.0" alignment="CENTER_LEFT" styleClass="player-row">
            <Label text="Jugador 4" styleClass="player-label" prefWidth="80" />
            <ComboBox fx:id="nombreJ4" promptText="Escribe tu nombre..." styleClass="config-field" prefWidth="200" />
            <ComboBox fx:id="colorJ4" promptText="Color" styleClass="config-combo" prefWidth="130" />
        </HBox>

        <!-- INFO CPU -->
        <Label fx:id="lblCPU" text="🦭  La Foca jugará como CPU automaticamente"
               styleClass="cpu-info" visible="false" managed="false" />

        <!-- AVISO ERROR -->
        <Label fx:id="lblError" text="" styleClass="error-label" visible="false" managed="false" />

    </VBox>

    <!-- BOTONES -->
    <HBox spacing="20.0" alignment="CENTER">
        <Button text="← Volver" onAction="#handleVolver" styleClass="menu-button, secondary-btn" prefWidth="160" />
        <Button text="¡Empezar! →" onAction="#handleEmpezar" styleClass="menu-button, primary-btn" prefWidth="200" />
    </HBox>

    <Label text="v1.0 - Darius, Eloy &amp; Unai Edition" styleClass="footer-text" />

</VBox>
