<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    PANTALLA DE VICTORIA
    - StackPane raíz: llena toda la ventana
    - ImageView: enlazado al tamaño de la escena en Java para llenar siempre la pantalla
    - VBox overlay: etiqueta + botones en la parte inferior, sobre la imagen
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="JOC_DEL_PINGU.PantallaVictoria"
           stylesheets="@PantallaVictoria.css"
           styleClass="victoria-root">

    <!-- Imagen de victoria: tamaño enlazado dinámicamente en el controlador -->
    <ImageView fx:id="imgVictoria"
               preserveRatio="false"
               StackPane.alignment="CENTER"/>

    <!-- Overlay inferior: gradiente oscuro + etiqueta + botones -->
    <VBox fx:id="overlayBottom"
          alignment="BOTTOM_CENTER" spacing="14"
          styleClass="victoria-overlay"
          StackPane.alignment="BOTTOM_CENTER">
        <padding>
            <Insets top="0" right="40" bottom="36" left="40"/>
        </padding>

        <!-- Nombre del ganador -->
        <Label fx:id="lblGanador" text="¡GANADOR!" styleClass="victoria-title"/>

        <!-- Botones de acción -->
        <HBox alignment="CENTER" spacing="24">
            <Button fx:id="btnNuevaPartida" text="🎮  NUEVA PARTIDA"
                    onAction="#handleNuevaPartida"
                    styleClass="victoria-btn, primary-btn"
                    prefWidth="220" prefHeight="52"/>
            <Button fx:id="btnGuardar" text="💾  GUARDAR"
                    onAction="#handleGuardar"
                    styleClass="victoria-btn"
                    prefWidth="180" prefHeight="52"/>
            <Button fx:id="btnMenu" text="🏠  MENÚ PRINCIPAL"
                    onAction="#handleMenu"
                    styleClass="victoria-btn"
                    prefWidth="220" prefHeight="52"/>
            <Button fx:id="btnSalir" text="❌  SALIR"
                    onAction="#handleSalir"
                    styleClass="victoria-btn, danger-btn"
                    prefWidth="160" prefHeight="52"/>
        </HBox>
    </VBox>

</StackPane>
